# Copy to .env and adjust. .env is gitignored; this file is committed.
# Compose substitutes these automatically when running from the repo root.

# --- Django ---
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# --- PostgreSQL ---
POSTGRES_DB=docuflow
POSTGRES_USER=docuflow
POSTGRES_PASSWORD=docuflow
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Inside containers use POSTGRES_HOST=postgres

# --- Redis (cache + Celery result backend) ---
REDIS_URL=redis://localhost:6379/0

# --- RabbitMQ (Celery broker) ---
RABBITMQ_DEFAULT_USER=docuflow
RABBITMQ_DEFAULT_PASS=docuflow
CELERY_BROKER_URL=amqp://docuflow:docuflow@localhost:5672//
# Inside containers use amqp://docuflow:docuflow@rabbitmq:5672//

# --- MinIO (S3-compatible object storage) ---
MINIO_ROOT_USER=docuflow
MINIO_ROOT_PASSWORD=docuflow123
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET_NAME=docuflow-documents
S3_ACCESS_KEY=docuflow
S3_SECRET_KEY=docuflow123
# Inside containers use S3_ENDPOINT_URL=http://minio:9000

# --- Extraction backend ---
EXTRACTOR_BACKEND=mock
